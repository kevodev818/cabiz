# ============================================
# CA Lead Engine — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# ============================================
# MICROSOFT OUTLOOK / GRAPH API (for emails)
# ============================================
# 1. Go to https://portal.azure.com
# 2. Navigate to Azure Active Directory > App registrations > New registration
# 3. Name: "CA Lead Engine", Redirect URI: http://localhost:3001/auth/callback
# 4. Under API Permissions, add: Mail.Send, Mail.ReadWrite, User.Read
# 5. Under Certificates & secrets, create a new client secret
# 6. Copy the values below:

AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
OUTLOOK_EMAIL=your-email@outlook.com

# ============================================
# SMTP FALLBACK (if not using Microsoft Graph)
# ============================================
# If you prefer simple SMTP instead of Graph API:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Your Name

# ============================================
# PHYSICAL MAILER SERVICE (pick one)
# ============================================
# Lob (https://lob.com) — handwritten-style mailers
LOB_API_KEY=your-lob-api-key
LOB_FROM_NAME=Your Name
LOB_FROM_ADDRESS=123 Main St
LOB_FROM_CITY=Los Angeles
LOB_FROM_STATE=CA
LOB_FROM_ZIP=90001

# OR Handwrytten (https://handwrytten.com)
# HANDWRYTTEN_API_KEY=your-handwrytten-api-key

# ============================================
# CA SECRETARY OF STATE SCRAPING
# ============================================
# The system scrapes bizfileonline.sos.ca.gov
# No API key needed — it's public data
# Adjust scan frequency (in minutes):
SCAN_INTERVAL_MINUTES=360
MAX_RESULTS_PER_SCAN=50

# ============================================
# APP SETTINGS
# ============================================
SENDER_NAME=Your Name
SENDER_COMPANY=Your Company
SENDER_PHONE=(310) 555-0100
SENDER_WEBSITE=https://yourwebsite.com
